{
  "name": "showcase",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "preview": "next dev",
    "db:local": "docker compose -f ../docker-compose.yml up -d postgres",
    "dev:setup": "npm run db:local && sleep 3 && npm run db:push && npm run db:seed",
    "build": "next build",
    "vercel-build": "tsx scripts/push-schema.ts && tsx scripts/seed.ts && tsx scripts/import-info-mrfox-news.ts && next build",
    "start": "next start",
    "lint": "eslint",
    "db:push": "drizzle-kit push",
    "db:push:remote": "tsx scripts/push-schema.ts",
    "db:generate": "drizzle-kit generate",
    "db:seed": "tsx scripts/seed.ts",
    "posters:generate": "tsx scripts/generate-app-posters.ts",
    "news:import": "tsx scripts/import-info-mrfox-news.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@neondatabase/serverless": "^1.1.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.2.3",
    "lucide-react": "^1.20.0",
    "next": "16.2.9",
    "next-intl": "^4.13.0",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.14.0",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "sharp": "^0.35.2",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
